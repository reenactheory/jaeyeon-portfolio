---
const year = new Date().getFullYear();
---

<footer class="bg-ink text-paper relative overflow-hidden">
  <div class="container-x pt-24 md:pt-40 pb-10">
    <p class="label opacity-60 text-[14px] md:text-[32px]">
      <span lang="ko">함께 작업해요!</span>
      <span lang="en">Let's work together!</span>
    </p>
    <a href="mailto:jenna.jaeyeon@gmail.com" class="block mt-6 h-display text-[clamp(1.5rem,7vw,7rem)] leading-[1.05] hover:italic transition-all duration-700">
      jenna.<wbr /><span class="h-serif-it">jaeyeon</span>@<wbr />gmail.com
    </a>

    <div class="mt-24 md:mt-40">
      <p class="label opacity-50 mb-6">
        <span lang="ko">메뉴</span><span lang="en">Index</span>
      </p>
      <nav class="border-y border-paper/15 divide-y divide-paper/15">
        {[
          { href: '/', n: '01', ko: '홈', en: 'Home' },
          { href: '/work', n: '02', ko: '작업', en: 'Work' },
          { href: '/about', n: '03', ko: '소개', en: 'About' },
          { href: '/contact', n: '04', ko: '연락', en: 'Contact' },
        ].map((item) => (
          <a
            href={item.href}
            class="group flex items-center justify-between py-5 md:py-7 transition-[padding] duration-700 ease-smooth hover:pl-3 md:hover:pl-5"
          >
            <span class="flex items-baseline gap-6 md:gap-10">
              <span class="label opacity-40 group-hover:opacity-90 transition-opacity">{item.n}</span>
              <span class="h-display text-2xl md:text-4xl tracking-tighter2 transition-transform duration-700 ease-smooth group-hover:translate-x-3">
                <span lang="ko">{item.ko}</span>
                <span lang="en">{item.en}</span>
              </span>
            </span>
            <span class="opacity-30 group-hover:opacity-100 transition-all duration-500 text-xl md:text-2xl group-hover:translate-x-1">→</span>
          </a>
        ))}
      </nav>
    </div>

    <div class="mt-24 pt-6 border-t border-paper/15 label opacity-50">
      <p>© {year} Jenna Story. All rights reserved.</p>
    </div>
  </div>
</footer>
