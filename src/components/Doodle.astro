---
interface Props {
  which: 'star' | 'spiral' | 'arrow' | 'squiggle' | 'asterisk' | 'circle';
  class?: string;
}
const { which, class: className = '' } = Astro.props;
---

{which === 'star' && (
  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class={className}>
    <path d="M32 6 C 33 22 38 30 56 32 C 38 34 33 42 32 58 C 31 42 26 34 8 32 C 26 30 31 22 32 6 Z" />
  </svg>
)}

{which === 'asterisk' && (
  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" class={className}>
    <path d="M32 8 V 56" />
    <path d="M8 32 H 56" />
    <path d="M14 14 L 50 50" />
    <path d="M50 14 L 14 50" />
  </svg>
)}

{which === 'spiral' && (
  <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class={className}>
    <path d="M40 40 m -2 0 a 2 2 0 1 0 4 0 a 2 2 0 1 0 -4 0 M40 32 a 8 8 0 1 1 -8 8 M40 22 a 18 18 0 1 1 -18 18 M40 10 a 30 30 0 1 1 -30 30" />
  </svg>
)}

{which === 'arrow' && (
  <svg viewBox="0 0 80 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className}>
    <path d="M4 16 Q 25 6 50 16 T 76 16" />
    <path d="M68 8 L 76 16 L 68 24" />
  </svg>
)}

{which === 'squiggle' && (
  <svg viewBox="0 0 120 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class={className}>
    <path d="M2 8 Q 17 -2 32 8 T 62 8 T 92 8 T 118 8" />
  </svg>
)}

{which === 'circle' && (
  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class={className}>
    <path d="M50 14 C 60 22 60 42 48 52 C 30 64 8 50 8 32 C 8 18 22 8 36 10 C 48 12 56 22 56 32" />
  </svg>
)}
