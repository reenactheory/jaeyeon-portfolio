---
import LangToggle from './LangToggle.astro';
const { pathname } = Astro.url;
const links = [
  { href: '/work', ko: '작업', en: 'Work' },
  { href: '/about', ko: '소개', en: 'About' },
  { href: '/contact', ko: '연락', en: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-paper text-ink border-b border-line">
  <nav class="container-x flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-2 group" aria-label="Jenna Story">
      <img src="/assets/logo.png" alt="Jenna Story" class="h-7 md:h-8 w-auto" />
    </a>

    <ul class="hidden md:flex items-center gap-10">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={`label link-line ${pathname.startsWith(l.href) ? 'opacity-100' : 'opacity-90'}`}
          >
            <span lang="ko">{l.ko}</span><span lang="en">{l.en}</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-6">
      <LangToggle />
    </div>

    <button id="mobile-toggle" class="md:hidden label" aria-label="Menu">
      <span lang="ko">메뉴</span><span lang="en">Menu</span>
    </button>
  </nav>

  <div id="mobile-menu" class="md:hidden hidden bg-ink text-paper container-x py-10 mix-blend-normal">
    <ul class="flex flex-col gap-6">
      {links.map((l) => (
        <li>
          <a href={l.href} class="h-display text-4xl block">
            <span lang="ko">{l.ko}</span><span lang="en">{l.en}</span>
          </a>
        </li>
      ))}
      <li class="pt-4 border-t border-paper/20">
        <span class="label opacity-70">Email</span>
        <a href="mailto:jenna.jaeyeon@gmail.com" class="block text-xl mt-1 break-all">jenna.jaeyeon@gmail.com</a>
      </li>
      <li class="pt-2">
        <span class="label opacity-70">Phone</span>
        <a href="tel:+821027822665" class="block text-xl mt-1">+82 10 2782 2665</a>
      </li>
      <li class="pt-4"><LangToggle /></li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
