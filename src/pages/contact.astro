---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="연락 — Jenna Story" hideFooter={false}>
  <section class="container-x pt-40 md:pt-56 pb-12">
    <p lang="ko" class="label text-mute mb-3">Contact</p>
    <h1 class="h-display text-[clamp(1.75rem,5vw,4.5rem)]">
      <span lang="ko" class="block">
        <span class="block mask-line"><span>편하게</span></span>
        <span class="block mask-line"><span><span class="h-serif-it">연락</span> 주세요.</span></span>
      </span>
      <span lang="en" class="block">
        <span class="block mask-line"><span>Feel free</span></span>
        <span class="block mask-line"><span>to <span class="h-serif-it">reach out</span>.</span></span>
      </span>
    </h1>
  </section>

  <section class="container-x py-16 md:py-24 grid md:grid-cols-12 gap-12 border-t border-line">
    <div class="md:col-span-5 space-y-10 reveal">
      <div>
        <p class="label text-mute mb-3 flex items-center gap-3">
          <span><span lang="ko">이메일</span><span lang="en">Email</span></span>
          <span class="copy-status opacity-0 transition-opacity duration-300 text-ink/70">
            <span lang="ko">복사됨</span><span lang="en">Copied</span>
          </span>
        </p>
        <button type="button" data-copy="jenna.jaeyeon@gmail.com" class="copy-btn block text-left w-full text-2xl md:text-3xl tracking-tighter2 link-line break-all">jenna.jaeyeon@gmail.com</button>
      </div>
      <div>
        <p class="label text-mute mb-3 flex items-center gap-3">
          <span><span lang="ko">전화번호</span><span lang="en">Phone</span></span>
          <span class="copy-status opacity-0 transition-opacity duration-300 text-ink/70">
            <span lang="ko">복사됨</span><span lang="en">Copied</span>
          </span>
        </p>
        <button type="button" data-copy="+82 10 2782 2665" class="copy-btn block text-left w-full text-2xl md:text-3xl tracking-tighter2 link-line">+82 10 2782 2665</button>
      </div>
    </div>

    <div class="md:col-span-6 md:col-start-7 reveal">
      <p class="text-lg md:text-xl leading-[1.75] text-ink/85">
        <span lang="ko">새로운 협업 제안, 가벼운 인사, 디자인 이야기 모두 환영합니다.<br />메일이나 문자로 편하게 남겨 주시면 확인하는 대로 답장드릴게요.</span>
        <span lang="en">New collaborations, a quick hello, or just a chat about design — all welcome. Drop me a note by email and I'll get back to you when I can.</span>
      </p>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.copy-btn');
  buttons.forEach((btn) => {
    btn.addEventListener('click', async () => {
      const value = btn.dataset.copy || btn.textContent || '';
      try {
        await navigator.clipboard.writeText(value);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = value;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const status = btn.parentElement?.querySelector('.copy-status') as HTMLElement | null;
      if (!status) return;
      status.style.opacity = '1';
      const existing = (status as any)._t as number | undefined;
      if (existing) window.clearTimeout(existing);
      (status as any)._t = window.setTimeout(() => {
        status.style.opacity = '0';
      }, 1500);
    });
  });
</script>
